# Database
DATABASE_PATH=./data/outage.db

# Polling
# POLL_INTERVAL_MINUTES must divide 60 (1, 2, 3, 4, 5, 6, 10, 12, 15, 20, 30, 60)
# so the cron schedule fires evenly. Other values are clamped to 3.
POLL_INTERVAL_MINUTES=3
# Required to enable POST /api/cron and (when ENABLE_RULES_API is unset) to
# authorize POST/PATCH/DELETE on /api/alerts/rules. Send as `Authorization: Bearer ...`.
CRON_SECRET=your-secret-token-here

# Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Enforce TLS certificate verification on the SMTP connection (default: true).
# Only set to false if your SMTP server uses a self-signed cert in dev.
SMTP_REJECT_UNAUTHORIZED=true
ALERT_FROM=outage-dashboard@yourdomain.com
# Fallback recipient list when no alert rule matches a triggered incident.
ALERT_EMAILS=admin@company.com,ops@company.com

# Alert Rules API
# Set to "true" to allow the alerts UI (and any client) to write to
# /api/alerts/rules without a Bearer token. Only do this on internal/trusted
# networks. If unset, writes require `Authorization: Bearer $CRON_SECRET`.
# ENABLE_RULES_API=false

# Downdetector
DOWNDETECTOR_ENABLED=true
DD_REPORT_THRESHOLD_DEGRADED=100
DD_REPORT_THRESHOLD_MAJOR=500

# Logging
# Set to "true" to enable verbose poller logs (per-service status lines).
# DEBUG=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Docker
# Host port to publish the container on. Change this if 3100 is already
# in use on the host (e.g. APP_PORT=3200 to expose at http://localhost:3200).
APP_PORT=3100
